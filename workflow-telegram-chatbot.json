    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Pega o texto do campo original (mude 'endereco' para o nome do seu campo atual)\nlet texto = $json.message.text || \"\";\n\n// 2. Remove acentos (Ex: \"São José\" vira \"Sao Jose\")\ntexto = texto.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n\n// 3. Remove caracteres especiais (mantém apenas letras, números, espaços e vírgulas)\ntexto = texto.replace(/[^a-zA-Z0-9,\\s]/g, \"\");\n\nlet indexVirgula = texto.indexOf(\",\");\n\nif (indexVirgula !== -1) {\n    let antes = texto.slice(0, indexVirgula);\n    let depois = texto.slice(indexVirgula);\n\n    // 4. Aplica as regras de espaços\n    antes = antes.trim().replace(/\\s+/g, \" \");\n    depois = depois.replace(/\\s+/g, \"\");\n\n    texto = antes + depois;\n}\n\n// 5. Salva o resultado diretamente no campo 'queue'\n$input.item.json.queue = texto;\n\n// 6. Retorna o item para o n8n\nreturn $input.item;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1376,
        -640
      ],
      "id": "5d9e85e5-ddf6-4d4f-9cde-793d6eb736b9",
      "name": "TratarEntrada",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\n// Captura a temperatura da sua variável de entrada\nconst tempOriginal = item.json.main.temp;\n\n// Salva o valor arredondado no novo campo tempConvertida\nitem.json.tempConvertida = Math.round(tempOriginal);\n\nreturn item;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
